# GaussOS environment configuration (copy to .env; values shown are defaults)

# --- Agent LLM (Anthropic / Claude) ---
# Required to enable live agent conversation execution. When unset, the agent
# layer reports "llm_not_configured" instead of fabricating responses.
ANTHROPIC_API_KEY=
# Optional model override (default: claude-sonnet-4-6)
ANTHROPIC_MODEL=claude-sonnet-4-6
# Optional API base URL override (e.g. a gateway/proxy)
ANTHROPIC_BASE_URL=https://api.anthropic.com

# --- Web UI ---
PORT=3000
BACKEND_URL=http://localhost:8080
