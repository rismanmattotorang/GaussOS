# GaussOS environment configuration (copy to .env)

# ======================================================================
# Agent LLM — flexible, multi-provider
# ----------------------------------------------------------------------
# Select a provider explicitly, or leave LLM_PROVIDER unset to auto-detect
# the first provider whose API key is present.
#   anthropic | openai | deepseek | qwen | byteplus | openrouter | custom
LLM_PROVIDER=openai

# Generic overrides (optional). LLM_API_KEY overrides the provider-specific
# key below; LLM_MODEL / LLM_BASE_URL override the provider defaults.
LLM_API_KEY=
LLM_MODEL=
LLM_BASE_URL=

# Provider-specific API keys (used when LLM_API_KEY is not set) ----------
ANTHROPIC_API_KEY=     # provider: anthropic  (default model claude-sonnet-4-6)
OPENAI_API_KEY=        # provider: openai     (default model gpt-4o-mini)
DEEPSEEK_API_KEY=      # provider: deepseek   (default model deepseek-chat)
DASHSCOPE_API_KEY=     # provider: qwen       (default model qwen-plus)
BYTEPLUS_API_KEY=      # provider: byteplus   (default model skylark-pro)
OPENROUTER_API_KEY=    # provider: openrouter (default model openai/gpt-4o-mini)

# 'custom' targets any OpenAI-compatible endpoint (e.g. Ollama, vLLM, LM Studio):
#   LLM_PROVIDER=custom
#   LLM_BASE_URL=http://localhost:11434/v1
#   LLM_MODEL=llama3.1
#   LLM_API_KEY=ollama

# ======================================================================
# Web UI
# ======================================================================
PORT=3000
BACKEND_URL=http://localhost:8080
